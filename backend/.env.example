# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devops_starter
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Configuration
JWT_ACCESS_SECRET=your-access-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_EMAIL_VERIFICATION_SECRET=your-email-verification-secret
JWT_PASSWORD_RESET_SECRET=your-password-reset-secret
JWT_EMAIL_VERIFICATION_EXPIRATION=24h
JWT_PASSWORD_RESET_EXPIRATION=1h

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=DevOps Starter

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
FRONTEND_VERIFICATION_URL=/verify-email
FRONTEND_RESET_PASSWORD_URL=/reset-password

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100      # Maximum requests per window
AUTH_RATE_LIMIT_WINDOW_MS=3600000 # 1 hour in milliseconds
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5    # Maximum login attempts per hour

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log