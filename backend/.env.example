const dotenv = require('dotenv');
const path = require('path');

// Charger les variables d'environnement
dotenv.config();

// JWT Configuration
process.env.JWT_ACCESS_SECRET = process.env.JWT_ACCESS_SECRET || 'your-access-secret-key';
process.env.JWT_REFRESH_SECRET = process.env.JWT_REFRESH_SECRET || 'your-refresh-secret-key';
process.env.JWT_EMAIL_VERIFICATION_SECRET = process.env.JWT_EMAIL_VERIFICATION_SECRET || 'your-email-verification-secret';
process.env.JWT_PASSWORD_RESET_SECRET = process.env.JWT_PASSWORD_RESET_SECRET || 'your-password-reset-secret';

// Google OAuth
process.env.GOOGLE_CLIENT_ID = 'your-google-client-id';
process.env.GOOGLE_CLIENT_SECRET = 'your-google-client-secret';
process.env.GOOGLE_CALLBACK_URL = 'http://localhost:3000/api/auth/google/callback';

// SMTP Configuration
process.env.SMTP_HOST = 'smtp.gmail.com';
process.env.SMTP_PORT = '587';
process.env.SMTP_SECURE = 'false';
process.env.SMTP_USER = 'your-email@gmail.com';
process.env.SMTP_PASS = 'your-email-password';
process.env.SMTP_FROM = 'your-email@gmail.com';

// Application
process.env.FRONTEND_URL = 'http://localhost:3000';
process.env.NODE_ENV = 'development';