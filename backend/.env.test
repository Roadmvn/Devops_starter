# Server Configuration
PORT=3001
NODE_ENV=test

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devops_starter_test
DB_USER=test_user
DB_PASSWORD=test_password

# JWT Configuration
JWT_ACCESS_SECRET=test_access_secret_key
JWT_REFRESH_SECRET=test_refresh_secret_key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_EMAIL_VERIFICATION_SECRET=test_email_verification_secret
JWT_PASSWORD_RESET_SECRET=test_password_reset_secret
JWT_EMAIL_VERIFICATION_EXPIRATION=24h
JWT_PASSWORD_RESET_EXPIRATION=1h

# Google OAuth Configuration (using mock values for tests)
GOOGLE_CLIENT_ID=test_google_client_id
GOOGLE_CLIENT_SECRET=test_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Email Configuration (using ethereal for testing)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=test@ethereal.email
SMTP_PASS=test_password
SMTP_FROM=test@ethereal.email
SMTP_FROM_NAME=DevOps Starter Test

# Frontend Configuration
FRONTEND_URL=http://localhost:3001
FRONTEND_VERIFICATION_URL=/verify-email
FRONTEND_RESET_PASSWORD_URL=/reset-password

# Security Configuration (reduced limits for testing)
RATE_LIMIT_WINDOW_MS=60000       # 1 minute in milliseconds
RATE_LIMIT_MAX_REQUESTS=1000     # Higher limit for testing
AUTH_RATE_LIMIT_WINDOW_MS=60000  # 1 minute in milliseconds
AUTH_RATE_LIMIT_MAX_ATTEMPTS=100 # Higher limit for testing

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE_PATH=logs/test.log
